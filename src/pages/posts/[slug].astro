---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const business = await getEntry(post.data.business);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const fmtDateTime = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });

const typeLabel = { blog: 'Blog', social: 'Social', video: 'Promo Video' } as const;

// Fetch comments on this post, oldest first (chronological reading order).
// In Astro 5, reference fields resolve to { id, collection } — match on id.
const allComments = await getCollection('comments');
const postComments = allComments
  .filter((c) => c.data.post.id === post.slug)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const renderedComments = await Promise.all(
  postComments.map(async (c) => {
    const { Content: CommentBody } = await c.render();
    const commentBiz = await getEntry(c.data.business);
    return { comment: c, commentBiz, CommentBody };
  })
);

// Convert YouTube/Vimeo/Google Drive URLs to embed URLs.
function embedUrl(url?: string): string | null {
  if (!url) return null;
  const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|v\/|shorts\/))([\w-]+)/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
  const vm = url.match(/vimeo\.com\/(\d+)/);
  if (vm) return `https://player.vimeo.com/video/${vm[1]}`;
  // Google Drive — supports both share-link formats:
  //   https://drive.google.com/file/d/<FILE_ID>/view?usp=sharing
  //   https://drive.google.com/open?id=<FILE_ID>
  const gdFile = url.match(/drive\.google\.com\/file\/d\/([\w-]+)/);
  if (gdFile) return `https://drive.google.com/file/d/${gdFile[1]}/preview`;
  const gdOpen = url.match(/drive\.google\.com\/open\?id=([\w-]+)/);
  if (gdOpen) return `https://drive.google.com/file/d/${gdOpen[1]}/preview`;
  return null;
}
const embed = embedUrl(post.data.videoUrl);
---

<Base title={post.data.title} description={`${typeLabel[post.data.type]} from ${business.data.name}`}>
  <article class="article">
    <h1 class="post-title">{post.data.title}</h1>
    <p class="post-meta">
      <a href={`/industries/${business.slug}`}>{business.data.name}</a>
      · {fmtDate(post.data.date)}
      · {typeLabel[post.data.type]}
    </p>

    {embed && (
      <div class="embed">
        <iframe
          src={embed}
          title={post.data.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    )}

    {post.data.image && (
      <p style="margin: 1.25rem 0;">
        <img src={post.data.image} alt={post.data.imageAlt ?? ''} loading="lazy" />
      </p>
    )}

    <div class="post-body">
      <Content />
    </div>

    <p style="margin-top: 2rem;">
      <a href={`/industries/${business.slug}`}>&larr; More from {business.data.name}</a>
    </p>

    <section class="comments" id="comments" aria-label="Comments">
      <h2 class="section-h">
        {renderedComments.length === 0 ? 'Comments' : `Comments (${renderedComments.length})`}
      </h2>

      {renderedComments.length === 0 ? (
        <p class="empty-state">
          No comments yet. <a href="/admin">Sign in to add one</a>.
        </p>
      ) : (
        <ul class="comments-list">
          {renderedComments.map(({ comment, commentBiz, CommentBody }) => (
            <li class="comment" data-comment-slug={comment.slug}>
              <p class="comment-meta">
                <a href={`/industries/${commentBiz.slug}`} class="biz">{commentBiz.data.name}</a>
                <span class="date"> · <time datetime={comment.data.date.toISOString()}>{fmtDateTime(comment.data.date)}</time></span>
                <button
                  type="button"
                  class="comment-delete"
                  data-comment-path={`src/content/comments/${comment.slug}.md`}
                  hidden
                  aria-label={`Delete comment by ${commentBiz.data.name}`}
                >Delete</button>
              </p>
              <div class="comment-body">
                <CommentBody />
              </div>
            </li>
          ))}
        </ul>
      )}

      <p class="comments-add">
        <a href="/admin">Add a comment as your business &rarr;</a>
      </p>
    </section>
  </article>
</Base>

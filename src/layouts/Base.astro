---
import { site } from '../site.config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
const desc = description ?? site.description;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={desc} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={site.url} />
  <meta property="og:image" content={`${site.url}/og-image.jpg`} />
  <link rel="alternate" type="application/rss+xml" title={`${site.name} feed`} href="/rss.xml" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>

  <main id="main">
    <h1 class="visually-hidden">{title ?? `${site.name} — ${site.tagline}`}</h1>
    <header class="masthead" role="banner">
      <a href="/" class="logo-link" aria-label={`${site.name} home`}>
        <img class="logo" src="/logo.jpg" alt={`${site.name} — ${site.tagline}`} width="932" height="326" />
      </a>
      <nav class="primary" aria-label="Primary">
        <a href="/#industries">Industries</a>
        <a href="/#posts">Recent Posts</a>
        <a href="/showcase">Showcase</a>
        <a href="/guide">Student Guide</a>
        <a href="/about">About</a>
        <a href="/admin" class="signin">Sign In</a>
      </nav>
    </header>

    <slot />

    <footer>
      A {site.course.split('—')[0].trim()} project · {site.institution} · {site.currentTerm} ·
      <a href={`mailto:${site.email}`}>{site.email}</a>
    </footer>
  </main>

  <script is:inline>
    // ============================================================
    // Netlify Identity bootstrap
    // ============================================================
    // 1. Redirect invite/recovery flows on non-/admin pages to /admin.
    // 2. Reveal inline "Delete" buttons on comments when a user is signed in.
    // Any signed-in user can delete any comment (community moderation).
    // Every deletion is a git commit via Git Gateway, audit-trail by design.
    // ============================================================

    function updateCommentDeleteButtons(user) {
      const buttons = document.querySelectorAll('.comment-delete');
      buttons.forEach((btn) => {
        if (user) {
          btn.hidden = false;
          if (!btn.dataset.bound) {
            btn.addEventListener('click', handleCommentDelete);
            btn.dataset.bound = '1';
          }
        } else {
          btn.hidden = true;
        }
      });
    }

    async function handleCommentDelete(e) {
      const btn = e.currentTarget;
      const path = btn.dataset.commentPath;
      if (!path) return;
      if (!confirm('Delete this comment? The deletion will be logged in the project history.')) return;

      btn.disabled = true;
      const originalText = btn.textContent;
      btn.textContent = 'Deleting…';

      try {
        const user = window.netlifyIdentity.currentUser();
        if (!user) throw new Error('Not signed in');
        const token = await user.jwt();

        const encodedPath = path.split('/').map(encodeURIComponent).join('/');

        // Fetch current file SHA (required by the GitHub contents API)
        const getResp = await fetch('/.netlify/git/github/contents/' + encodedPath + '?ref=main', {
          headers: { Authorization: 'Bearer ' + token },
        });
        if (!getResp.ok) throw new Error('Could not look up comment (' + getResp.status + ')');
        const fileData = await getResp.json();

        // DELETE the comment file
        const delResp = await fetch('/.netlify/git/github/contents/' + encodedPath, {
          method: 'DELETE',
          headers: {
            Authorization: 'Bearer ' + token,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            message: 'Delete comment via inline button',
            sha: fileData.sha,
            branch: 'main',
          }),
        });
        if (!delResp.ok) throw new Error('Delete failed (' + delResp.status + ')');

        // Remove from DOM. Netlify will rebuild within ~60s.
        const commentEl = btn.closest('.comment');
        if (commentEl) {
          commentEl.style.opacity = '0.4';
          commentEl.style.transition = 'opacity 0.3s';
          setTimeout(() => commentEl.remove(), 350);
        }
      } catch (err) {
        btn.disabled = false;
        btn.textContent = originalText;
        alert('Could not delete: ' + (err.message || 'unknown error'));
      }
    }

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', (user) => {
        // Invite/recovery flows on non-/admin pages: send to /admin.
        if (!user && !location.pathname.startsWith('/admin')) {
          window.netlifyIdentity.on('login', () => {
            document.location.href = '/admin/';
          });
        }
        updateCommentDeleteButtons(user);
      });
      window.netlifyIdentity.on('login', (user) => updateCommentDeleteButtons(user));
      window.netlifyIdentity.on('logout', () => updateCommentDeleteButtons(null));
    }
  </script>
</body>
</html>
